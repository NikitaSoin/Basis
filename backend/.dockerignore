# Не тащим в Docker-образ то, что НЕ нужно в рантайме — образ/сборка резко легче,
# меньше нагрузка на диск билд-сервера. Файлы остаются в репозитории (это не git rm).

.git/
**/__pycache__/
*.pyc
.pytest_cache/

# Исходные PDF-отчёты и скретч анализа (~200 МБ): приложение их НЕ отдаёт —
# в рантайме нужны только companies/<T>/*.md и *.json. sources/ включает tmp/tmp_pdfs.
companies/**/sources/

# Локальное окружение разработки
.venv/
venv/
node_modules/
